<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- CloudKit and IAP entitlements are intentionally omitted until the app is -->
	<!-- registered in the Apple Developer Portal with proper provisioning.        -->
	<!-- To re-enable: add iCloud + CloudKit capabilities in Xcode target editor, -->
	<!-- then restore com.apple.developer.icloud-container-identifiers,           -->
	<!-- com.apple.developer.icloud-services, and com.apple.developer.in-app-payments. -->
</dict>
</plist>
